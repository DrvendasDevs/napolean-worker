{
  "name": "napoleon-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Worker assíncrono do pipeline de avaliação comercial Napoleon (transcrição, OCR, RAG, avaliação, PDFs, entrega WhatsApp).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "dotenv": "^16.4.7",
    "mammoth": "^1.9.0",
    "openai": "^4.77.0",
    "pdfkit": "^0.15.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pdfkit": "^0.13.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

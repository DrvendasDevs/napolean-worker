# =====================================================
# Worker Napoleon — variáveis de ambiente
# =====================================================

# Supabase (OBRIGATÓRIO) — service_role NUNCA vai para o frontend
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui

# Identificação/execução do worker
WORKER_ID=worker-1
WORKER_POLL_INTERVAL_MS=3000
WORKER_MAX_ATTEMPTS=5
WORKER_TMP_DIR=/tmp/napoleon
TZ=America/Sao_Paulo

# Buckets privados (devem existir — criados pela migration 023)
BUCKET_MEDIA=napoleon-media
BUCKET_ARTIFACTS=napoleon-artifacts
BUCKET_DOCUMENTS=napoleon-documents

# Transcrição (OpenAI Whisper) e chunking de áudio longo
WHISPER_MODEL=whisper-1
AUDIO_CHUNK_SECONDS=600
AUDIO_CHUNK_OVERLAP_SECONDS=3

# Embeddings (RAG)
EMBEDDING_MODEL=text-embedding-3-small

# OCR (Tesseract)
OCR_LANG=por+eng
OCR_BATCH_PAGES=5

# Caminhos de ferramentas (padrões funcionam no container)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
PDFTOTEXT_PATH=pdftotext
PDFTOPPM_PATH=pdftoppm
TESSERACT_PATH=tesseract
